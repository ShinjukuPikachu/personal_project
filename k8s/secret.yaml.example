# Copy to k8s/secret.yaml and fill in your actual values
# Then: kubectl apply -f k8s/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: release-pilot-secrets
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "your-anthropic-api-key-here"
  SLACK_BOT_TOKEN: "xoxb-your-token-here"
  SLACK_CHANNEL: "C0BDFHM8EA2"
